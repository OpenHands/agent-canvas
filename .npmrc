# Enable legacy peer-dependency resolution for the whole project.
#
# A few rule-only ESLint plugins we depend on (most notably
# `eslint-plugin-prettier`, which still declares its ESLint peer as
# `>=8.0.0 <10.0.0-0`) lag behind in updating their peer ranges. Even though
# those plugins don't actually exercise any of the ESLint APIs that change
# across majors, npm would still refuse to install them without this flag.
#
# Drop this file once upstream releases catch up.
legacy-peer-deps=true
